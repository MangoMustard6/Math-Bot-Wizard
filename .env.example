# Copy this file to .env and fill in your values.
# In Replit, add these as Secrets instead of a plain .env file.

DISCORD_TOKEN=your_discord_bot_token_here
DEFAULT_PREFIX=!
GEMINI_API_KEY=your_google_gemini_api_key_here

# Optional but recommended: your server (guild) ID for INSTANT slash command sync.
# Without this, new slash commands can take up to 1 hour to appear in Discord.
# To find it: Discord → right-click your server name → Copy Server ID
# (Developer Mode must be on: User Settings → Advanced → Developer Mode)
GUILD_ID=your_discord_server_id_here
